   <string notr="true">/* =========================
   VENTANA PRINCIPAL
   ========================= */
QMainWindow {
    background-color: #121212;
    color: #e0e0e0;
    font-family: &quot;Segoe UI&quot;;
}

/* Área central */
QWidget {
    background-color: #121212;
    color: #e0e0e0;
}

/* =========================
   BARRA DE MENÚ
   ========================= */
QMenuBar {
    background-color: #1e1e1e;
    color: white;
    border-bottom: 1px solid #303030;
}

QMenuBar::item {
    background: transparent;
    padding: 6px 12px;
}

QMenuBar::item:selected {
    background-color: #2d2d2d;
    border-radius: 4px;
}

/* =========================
   MENÚS DESPLEGABLES
   ========================= */
QMenu {
    background-color: #1e1e1e;
    color: white;
    border: 1px solid #404040;
}

QMenu::item {
    padding: 8px 25px;
}

QMenu::item:selected {
    background-color: #353535;
}

QMenu::separator {
    height: 1px;
    background-color: #505050;
    margin: 5px 10px;
}

/* =========================
   BARRA DE ESTADO
   ========================= */
QStatusBar {
    background-color: #1e1e1e;
    color: #d0d0d0;
    border-top: 1px solid #303030;
}</string>
