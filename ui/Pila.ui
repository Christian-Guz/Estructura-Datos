   <string notr="true">/* =========================
   VENTANA PRINCIPAL
   ========================= */
QDialog {
    background-color: #1e1e1e;
    border: 1px solid #303030;
    border-radius: 12px;
    font-family: &quot;Segoe UI&quot;;
    color: #f0f0f0;
}

/* =========================
   ETIQUETAS
   ========================= */
QLabel {
    color: #e0e0e0;
    font-weight: 500;
    background: transparent;
}

/* =========================
   CAJAS DE TEXTO
   ========================= */
QLineEdit {
    background-color: #2b2b2b;
    color: #ffffff;
    border: 2px solid #404040;
    border-radius: 8px;
    padding: 8px;
    selection-background-color: #3d8bfd;
}

QLineEdit:focus {
    border: 2px solid #3d8bfd;
    background-color: #333333;
}

QLineEdit:disabled {
    background-color: #252525;
    color: #808080;
}

/* =========================
   BOTONES
   ========================= */
QPushButton {
    background-color: transparent;
    color: white;
    border: 2px solid #5a5a5a;
    border-radius: 8px;
    padding: 8px 14px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #333333;
}

QPushButton:pressed {
    background-color: #252525;
}
/* =========================
   TOOLTIP
   ========================= */
QToolTip {
    background-color: #2b2b2b;
    color: white;
    border: 1px solid #3d8bfd;
    padding: 5px;
}</string>
